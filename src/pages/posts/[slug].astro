---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Category → URL mapping for back link
const categoryUrlMap: Record<string, string> = {
  '游戏动态': '/game/page/1',
  'IT 动态': '/it/page/1',
  '新游发现': '/new-games/page/1',
};
const categoryAbsoluteUrlMap: Record<string, string> = {
  '游戏动态': 'https://aippletree.com/game/page/1',
  'IT 动态': 'https://aippletree.com/it/page/1',
  '新游发现': 'https://aippletree.com/new-games/page/1',
};
const categoryUrl = post.data.category ? categoryUrlMap[post.data.category] : null;
const categoryAbsoluteUrl = post.data.category ? categoryAbsoluteUrlMap[post.data.category] : null;

const canonicalUrl = `https://aippletree.com/posts/${post.slug}/`;
const publishDateStr = post.data.publishDate.toISOString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": post.data.title,
  "description": post.data.description || '',
  "datePublished": publishDateStr,
  "dateModified": publishDateStr,
  "author": {
    "@type": "Organization",
    "name": "Gaming Digest"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Gaming Digest",
    "logo": {
      "@type": "ImageObject",
      "url": "https://aippletree.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
};

const breadcrumbItems: { "@type": string; position: number; name: string; item: string }[] = [
  { "@type": "ListItem", position: 1, name: "首页", item: "https://aippletree.com/" },
];
if (post.data.category && categoryAbsoluteUrl) {
  breadcrumbItems.push({ "@type": "ListItem", position: 2, name: post.data.category, item: categoryAbsoluteUrl });
  breadcrumbItems.push({ "@type": "ListItem", position: 3, name: post.data.title, item: canonicalUrl });
} else {
  breadcrumbItems.push({ "@type": "ListItem", position: 2, name: post.data.title, item: canonicalUrl });
}

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems,
};
---

<SiteLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonicalUrl}
  ogType="article"
  publishDate={publishDateStr}
>
  <nav class="breadcrumb" aria-label="breadcrumb">
    <ol>
      <li><a href="/">首页</a></li>
      {post.data.category && categoryUrl && <li><a href={categoryUrl}>{post.data.category}</a></li>}
      <li><span>{post.data.title}</span></li>
    </ol>
  </nav>
  <article class="post">
    <header>
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={publishDateStr}>
          {post.data.publishDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
        {post.data.category && <span class="category">{post.data.category}</span>}
        {post.data.source && <span class="source">· 来源：{post.data.source}</span>}
      </p>
    </header>
    
    <div class="content">
      <Content />
    </div>
    
    {categoryUrl && (
      <footer>
        <a href={categoryUrl} class="back-link">← 返回{post.data.category}</a>
      </footer>
    )}
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
  
  <!-- 外部链接新窗口打开 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const content = document.querySelector('.content');
      if (content) {
        const links = content.querySelectorAll('a[href^="http"]');
        links.forEach(link => {
          link.setAttribute('target', '_blank');
          link.setAttribute('rel', 'noopener noreferrer');
        });
      }
    });
  </script>
</SiteLayout>

<style>
  .breadcrumb {
    max-width: 800px;
    margin: 0 auto 1rem;
    padding: 0 2rem;
    font-size: 0.9rem;
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .breadcrumb li::before {
    content: "/";
    margin-right: 0.5rem;
    color: #999;
  }

  .breadcrumb li:first-child::before {
    content: "";
  }

  .breadcrumb a {
    color: #06c;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb span {
    color: #666;
  }

  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  
  header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }
  
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
    line-height: 1.3;
  }
  
  .meta {
    color: #999;
    font-size: 0.95rem;
  }
  
  .source {
    color: #666;
  }
  
  .category {
    display: inline-block;
    background: #e8f4fd;
    color: #0066cc;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    margin-left: 0.5rem;
  }
  
  .content {
    line-height: 1.8;
    color: #333;
  }
  
  .content h2 {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    color: #1a1a1a;
  }
  
  .content h3 {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
    color: #333;
  }
  
  .content p {
    margin: 1rem 0;
  }
  
  .content ul, .content ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  
  .content li {
    margin: 0.5rem 0;
  }
  
  .content a {
    color: #0066cc;
    text-decoration: underline;
  }
  
  .content code {
    background: #f5f5f5;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-family: "SF Mono", Monaco, "Cascadia Code", monospace;
    font-size: 0.9em;
  }
  
  .content pre {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  
  .content pre code {
    background: none;
    padding: 0;
  }
  
  .content blockquote {
    border-left: 4px solid #0066cc;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #666;
    font-style: italic;
  }
  
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
  
  .back-link {
    color: #666;
    text-decoration: none;
  }
  
  .back-link:hover {
    color: #0066cc;
  }
</style>
